# Junior Aladdin — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is already in .gitignore.

# Environment: development | test | production
# Default: development
# ENV=development

# Angel One API Credentials (REQUIRED for live data)
# Get these from https://smartapi.angelbroking.com/
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_API_KEY=
ANGEL_ONE_PIN=

# Capital Limits (in INR)
# CAPITAL_PAPER_LIMIT=100000
# CAPITAL_REAL_LIMIT=50000
# CAPITAL_MAX_LOSS_PER_TRADE=5000
